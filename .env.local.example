# Google OAuth Configuration
# Get your Client ID from https://console.cloud.google.com
# 1. Create a new project or use existing one
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs: http://localhost:5174, http://localhost:3000, etc.
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# API Configuration
# Local:
# VITE_API_BASE_URL=http://127.0.0.1:8000
#
# Production:
VITE_API_BASE_URL=https://admin-rpnzl.vercel.app
